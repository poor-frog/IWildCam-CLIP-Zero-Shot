{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poor-frog.local/schemas/drm-wise-stp-reproducibility-manifest-v1.json",
  "title": "DRM-WiSE-STP reproducibility manifest",
  "type": "object",
  "required": [
    "schema_version",
    "experiment_id",
    "status",
    "claim_boundary",
    "result_run",
    "source_checkout",
    "execution",
    "checkpoint",
    "dataset_protocol",
    "selected_configuration",
    "wise_selection",
    "final_metrics",
    "source_files",
    "runtime_mutations",
    "known_provenance_gaps"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "experiment_id": {"const": "drm-wise-stp-v0-iwildcam"},
    "manifest_created_at": {"type": "string"},
    "status": {"const": "current_best_observed_single_checkpoint_result"},
    "claim_boundary": {"type": "object"},
    "result_run": {
      "type": "object",
      "required": ["provider", "run_id", "url", "state", "created_at"],
      "properties": {
        "provider": {"const": "weights_and_biases"},
        "run_id": {"const": "03gg65vx"},
        "url": {"type": "string"},
        "state": {"const": "finished"},
        "created_at": {"type": "string"}
      }
    },
    "source_checkout": {
      "type": "object",
      "required": ["remote", "commit", "verification"],
      "properties": {
        "remote": {"type": "string"},
        "commit": {"pattern": "^[0-9a-f]{40}$", "type": "string"},
        "verification": {"type": "string"}
      }
    },
    "manifest_generation_checkout": {"type": "object"},
    "execution": {"type": "object"},
    "checkpoint": {"type": "object"},
    "dataset_protocol": {"type": "object"},
    "selected_configuration": {
      "type": "object",
      "required": ["wise_alpha", "prototype_scale", "prototype_k", "sequence_eta"],
      "properties": {
        "wise_alpha": {"const": 0.2},
        "prototype_scale": {"const": 50.0},
        "prototype_k": {"const": 1},
        "sequence_eta": {"const": 0.5}
      }
    },
    "wise_selection": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["alpha", "run_id", "val_macro_f1"]
      }
    },
    "final_metrics": {
      "type": "object",
      "required": ["IWildCamIDVal", "IWildCamVal", "IWildCamID", "IWildCamOOD"],
      "additionalProperties": {
        "type": "object",
        "required": ["top1", "macro_f1"],
        "properties": {
          "top1": {"minimum": 0, "maximum": 1, "type": "number"},
          "macro_f1": {"minimum": 0, "maximum": 1, "type": "number"}
        }
      }
    },
    "source_files": {"type": "array", "minItems": 1},
    "runtime_mutations": {"type": "object"},
    "local_evidence": {"type": "array"},
    "wandb_file_inventory": {"type": "array"},
    "known_provenance_gaps": {"type": "array", "minItems": 1}
  }
}
